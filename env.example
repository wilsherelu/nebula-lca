# Compose project name
COMPOSE_PROJECT_NAME=nebula-lca

# Public frontend port on host
WEB_PORT=16988

# API runtime
DEBUG=false
ADMIN_TOKEN=change_me_to_a_strong_token

# Startup maintenance / bootstrap
AUTO_BOOTSTRAP_REFERENCE_DATA_ON_STARTUP=true
KEEP_LATEST_VERSIONS_PER_PROJECT=1000
AUTO_PRUNE_ON_STARTUP=true
AUTO_VACUUM_AFTER_PRUNE_ON_STARTUP=false
